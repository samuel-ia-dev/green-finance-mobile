{
  "name": "green-finance-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "cf:whoami": "wrangler whoami",
    "cf:d1:migrate": "wrangler d1 migrations apply green-finance-backend-db --remote",
    "cf:deploy": "wrangler deploy",
    "cf:pages:build": "node scripts/build-pages-pwa.cjs",
    "eas:build:android": "eas build --platform android --profile preview",
    "eas:build:production": "eas build --platform all --profile production",
    "eas:update:preview": "eas update --channel preview",
    "eas:update:production": "eas update --channel production",
    "lint": "eslint src __tests__ App.tsx jest.setup.ts scripts/check-coverage.cjs --ext .ts,.tsx,.js,.cjs",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand && node scripts/check-coverage.cjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.1.2",
    "@react-navigation/native": "^7.1.1",
    "@react-navigation/native-stack": "^7.1.5",
    "expo": "~52.0.25",
    "expo-file-system": "~18.0.12",
    "expo-linear-gradient": "~14.0.2",
    "expo-local-authentication": "~15.0.2",
    "expo-print": "~14.0.2",
    "expo-secure-store": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "firebase": "^11.8.1",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "^0.19.13",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "~18.3.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "eas-cli": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.2",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.7.3"
  }
}
