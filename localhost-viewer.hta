<html>
  <head>
    <title>Green Finance Localhost</title>
    <hta:application
      id="GreenFinanceLocal"
      applicationname="GreenFinanceLocal"
      border="thin"
      borderstyle="normal"
      caption="yes"
      maximizebutton="yes"
      minimizebutton="yes"
      scroll="no"
      singleinstance="yes"
      sysmenu="yes"
      windowstate="normal"
    />
    <script language="javascript">
      function boot() {
        try {
          window.moveTo(0, 0);
          window.resizeTo(screen.availWidth, screen.availHeight);
          window.focus();
          document.getElementById("appframe").src = "http://127.0.0.1:19011/?ts=" + new Date().getTime();
        } catch (error) {}
      }
    </script>
    <style>
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #0b1020;
      }
      iframe {
        border: 0;
        width: 100%;
        height: 100%;
      }
    </style>
  </head>
  <body onload="boot()">
    <iframe id="appframe" title="Green Finance"></iframe>
  </body>
</html>
